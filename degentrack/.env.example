TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
HELIUS_API_KEY=your_helius_api_key_here

# Moralis (https://moralis.com) — EVM data, the Helius equivalent for
# ETH/BSC/Base/Arbitrum. Powers: (1) token-card fallback when DexScreener has
# no pair yet (fresh BSC memes), (2) EVM wallet watching (/watch 0x…).
# Optional: without it EVM wallet tracking is disabled and cards use DexScreener only.
MORALIS_API_KEY=

# EVM wallet polling (only used when MORALIS_API_KEY is set).
# Chains to check for watched 0x wallets (moralis slugs: eth,bsc,base,arbitrum)
EVM_WATCH_CHAINS=bsc,eth
# How often to check for new swaps, in seconds. Lower = faster alerts but more
# Moralis compute units. Rough math: wallets × chains × (86400/interval) calls/day.
EVM_POLL_SECONDS=180
WATCHED_WALLETS=WalletAddress1,WalletAddress2
BOT_USERNAME=testttttt333bot

# Referral codes for trade deep-links (optional).
# Leave blank to send users straight to the platform without a referral.
TROJAN_REF=
BULLX_REF=
PHOTON_REF=
