generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GroupTokenCall {
  id             String   @id @default(cuid())
  groupId        BigInt
  mint           String
  symbol         String   @default("")
  name           String   @default("")
  calledAt       DateTime @default(now())
  callerId       BigInt   @default(0) // Telegram user id who posted the CA (0 = unknown / pre-migration)
  callerUsername String   @default("")
  priceAtCall    Float    @default(0) // token price at call time (USD)
  mcAtCall       Float    @default(0) // market cap at call time (USD)

  @@index([groupId, calledAt])
  @@index([groupId, mint])
  @@index([groupId, callerId])
}

model TokenPeak {
  mint          String   @id
  peakMcUsd     Float    @default(0)
  peakAt        DateTime @default(now())
  lastCheckedAt DateTime @default(now())
  lastMcUsd     Float    @default(0)
}

model Trade {
  id             String           @id @default(cuid())
  walletAddress  String
  wallet         Wallet           @relation(fields: [walletAddress], references: [address])
  type           String           // 'BUY' | 'SELL' | 'SWAP'
  tokenMint      String           // the primary token (received on BUY, spent on SELL)
  tokenSymbol    String
  tokenName      String           @default("")
  tokenAmount    Float            // amount of token
  priceUsd       Float            @default(0) // price per token at trade time
  totalUsd       Float            @default(0) // total USD value
  marketCapUsd   Float            @default(0) // mcap at trade time
  solAmount      Float            @default(0)
  signature      String           @unique
  timestamp      DateTime         @default(now())

  @@index([walletAddress, tokenMint])
  @@index([walletAddress, timestamp])
}

model User {
  id             BigInt           @id // Telegram chatId
  username       String?
  minTradeSize   Float            @default(0)
  firstSeen      DateTime         @default(now())
  lastSeen       DateTime         @updatedAt
  
  // Relations
  watchedWallets WatchedWallet[]
}

model Wallet {
  address        String           @id // Solana address
  
  // Relations
  watchers       WatchedWallet[]
  trades         Trade[]
}

model WatchedWallet {
  user           User             @relation(fields: [userId], references: [id])
  userId         BigInt
  wallet         Wallet           @relation(fields: [walletAddress], references: [address])
  walletAddress  String
  label          String?
  tags           String[]         @default([]) // Array of tags: "whale", "degen", "smart-money", etc.
  paused         Boolean          @default(false)
  minTradeSize   Float?           // per-wallet override; null = use global user setting

  @@id([userId, walletAddress]) // Composite primary key
}
